# BE MOCKOON:
VITE_BASE_URL_MOCKOON = "http://localhost:3000"
 
# BE LOCALE:
VITE_BASE_URL_LOCAL = "http://127.0.0.1:8000"

# BE SERVER:
VITE_BASE_URL_SERVER = "http://127.0.0.1:8000"



# valori: "cookie" | "token"
REACT_APP_AUTH_MODE=token                          

# valori: "session" | "local" (solo per mode=token)
REACT_APP_TOKEN_STORAGE=local   
     